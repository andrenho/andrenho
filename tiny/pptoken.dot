digraph fsm {

  rankdir = "LR";
  size = "8.5";
  node [ shape = doublecircle ]; START; IDENTIFIER; PPNUMBER; CHAR; STRING; 
    PREPROC; HEADER; ENTER; WHITESPACE;
  node [ shape = circle];

//  node [ label = "" ]; A; B; C; D; E; F; G; H; I; J; K; L; M; N;

  START -> A [ label = "U,L" ];
  START -> H [ label = "u" ];
  START -> B [ label = "R" ];
  START -> C [ label = "[A-z_] ![u,U,L,R]" ];
  START -> D [ label = "[0-9]" ];
  START -> F [ label = "'" ];
  START -> G [ label = "\", !after_include" ];
  START -> M [ label = "\", after_include" ];
  START -> J [ label = "preproc" ];
  START -> K [ label = "<" ];
  START -> WHITESPACE [ label = "' '" ];
  START -> ENTER [ label = "\\n" ];

  A -> C [ label = "!'" ];
  H -> C [ label = "!'" ];
  B -> C [ label = "!'" ];
  C -> C [ label = "[A-z0-9_]" ];
  C -> IDENTIFIER [ label = "![A-z0-9_], !is_prepoc" ];
  C -> PREPROC [ label = "![A-z0-9_], is_prepoc" ];

  D -> D [ label = "[A-z0-9_.] ![eE]" ];
  D -> PPNUMBER [ label = "![A-z0-9_.]" ];
  D -> E [ label = "[eE]" ];
  E -> PPNUMBER [ label = "[+-]" ];

  A -> F [ label = "'" ];
  H -> F [ label = "'" ];
  F -> F [ label = "!['\\n\\],esc" ];
  F -> CHAR [ label = "'" ];

  A -> G [ label = "\"" ];
  H -> G [ label = "\"" ];
  H -> I [ label = "8" ];
  I -> G [ label = "\"" ];
  G -> G [ label = "!['\\n\\\\],esc" ];
  G -> STRING [ label = "\"" ];

  J -> J [ label = "prepoc, next_is_prepoc" ];
  J -> PREPROC [ label = "!next_is_prepoc, is_preproc" ];

  K -> J [ label = "prepoc" ];
  K -> L [ label = "![\\n>]" ];
  L -> HEADER [ label = ">" ];

  M -> N [ label = "![\\n\"]" ];
  N -> HEADER [ label = "\"" ];

}

// missing
//  - raw strings
//  - unversal char set, unicode
