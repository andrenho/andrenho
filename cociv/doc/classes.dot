digraph G {
  fontname = "DejaVu Sans"
  fontsize = 8

  node [
    fontname = "DejaVu Sans"
    fontsize = 8
    shape = "Mrecord"
  ]

  edge [
    fontname = "DejaVu Sans"
    fontsize = 8
  ]

  Driver [
    label = "{Driver | focused\l | join(player)\lplayer_nation_active?\lrun_round!(display)\l }"
  ]
  Driver -> Game [ label = "game" ]

  Game [
    label = "{Game | map_w,map_h\lyear\l | # load\l# save!\l[](x,y)\lstart_round!\ladvance_round\lcheck_for_nation_elimination!\l }"
  ]
  Game -> Nation [ label = "player, nations" ]
  Game -> Tile [ label = "@tiles" ]

  Tile [ 
    label = "{Tile | x,y\lknown\lriver,plow,road\l|units\lcost_to_enter(unit)\lcan_build_city?\lworker=(unit)\lproduction\lproductivity_job(job)\labs_productivity(good)\l}"
  ]
  Tile -> Terrain [ label = "terrain" ]
  Tile -> City [ label = "city, belongs_to" ]
  Tile -> Unit [ label = "worker" ]

  Nation [
    label = "{Nation | name\lgold\l | create_unit!(unit)\lautoplay!\lstart_round!\lend_round!\lround_over?\lkill!(unit)\l }"
  ]
  Nation -> Unit [ label = "units" ]
  Nation -> City [ label = "cities" ]

  Unit [ 
    label = "{Unit | x,y\lold_x,old_y\lmoves_left\lextra\l | move(dir)\linit_round!\lend_round\lhas_moves_left?\ldescription\ltile\lcan_build_city?\lworker?\lsight\l }"
  ]
  Unit -> Nation [ label = "nation" ]
  Unit -> Military [ label = "military" ]

  LandUnit -> Unit [ arrowhead = "empty" ]
  LandUnit [ 
    label = "{LandUnit || move_ok?}"
  ]

  SeaUnit -> Unit [ arrowhead = "empty" ]
  SeaUnit [ 
    label = "{SeaUnit || move_ok?}"
  ]

  Unit -> Cargo [ style = "dashed" ];
  Cargo [
    label = "{Cargo||load(good,amt)\lunload(slot,amt)\l}"
    style = "dashed"
  ]
  
  Cargo -> Slot [ label="slot", style = "dashed" ];
  Slot [
    label = "{Slot|good\lamount}"
    style = "dashed"
  ]

  City [
    label = "{City | name\lx,y\l|}"
  ]
  City -> Nation [ label = "nation" ]

  CityForeign -> City [ arrowhead = "empty" ]
  CityForeign [
    label = "{CityForeign||}"
  ]

  CityPlayer -> City [ arrowhead = "empty" ]
  CityPlayer [
    label = "{CityPlayer || food_consumption\lproduction\lbuildable\lresidents\linit_round!\lhas_docks?\l }"
  ]
  CityPlayer -> Building [ label = "buildings" ]
  CityPlayer -> BuildingType [ label = "under_construction" ]
  CityPlayer -> Warehouse [ label = "warehouse" ]

  Building [
    label = "{Building || employ(unit)\lproduction\l}"
  ]
  Building -> BuildingType [ label = "type" ]
  Building -> Unit [ label = "workers" ]
  Building -> City [ label = "city" ]

  Warehouse -> Building [ arrowhead = "empty" ]

}
