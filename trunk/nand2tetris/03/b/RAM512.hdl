// File name: projects/03/b/RAM512.hdl

/**
 * Memory of 512 registers, each 16-bit wide.  
 * The chip facilitates read and write operations, as follows:
 *     Read:  out(t) = RAM512[address(t)](t)
 *     Write: If load(t-1) then RAM512[address(t-1)](t) = in(t-1)
 * In words: the chip always outputs the value stored at the memory 
 * location specified by address. If load == 1, the in value is loaded 
 * into the memory location specified by address.  This value becomes 
 * available through the out output starting from the next time step.
 */

CHIP RAM512 {
    IN in[16], load, address[9];
    OUT out[16];

    PARTS:
    DMux8Way(in=load, sel=address[6..8], a=ld0, b=ld1, c=ld2, d=ld3, e=ld4, f=ld5, g=ld6, h=ld7);

    RAM64(in=in, load=ld0, address=address[0..5], out=outa);
    RAM64(in=in, load=ld1, address=address[0..5], out=outb);
    RAM64(in=in, load=ld2, address=address[0..5], out=outc);
    RAM64(in=in, load=ld3, address=address[0..5], out=outd);
    RAM64(in=in, load=ld4, address=address[0..5], out=oute);
    RAM64(in=in, load=ld5, address=address[0..5], out=outf);
    RAM64(in=in, load=ld6, address=address[0..5], out=outg);
    RAM64(in=in, load=ld7, address=address[0..5], out=outh);

    Mux4Way16(a=outa, b=outb, c=outc, d=outd, sel=address[6..7], out=outx);
    Mux4Way16(a=oute, b=outf, c=outg, d=outh, sel=address[6..7], out=outy);

    Mux16(a=outx, b=outy, sel=address[8], out=out); 

}
