digraph G {

  rankdir = LR;
	node [shape=record];
  UniManager;
  trail [label="Gerenciador\nde trilhas"];
  cadastro [label="Cadastro|{Time|Data do evento}|{Indentity|Docente}"];
  trocalocal [label="TrocaLocal|{Activity|Entrada ou saida}|{Time|Hora do evento}|{Location|Localização}|{Indentity|Docente}"];
  avaliacao [label="Avaliacao|{Activity|Avaliação}|{Time|Hora do evento}|{Location|Localização}|{Identity|Docente}"];

  UniManager -> trocalocal -> trail;
  UniManager -> cadastro -> trail;
  UniManager -> avaliacao -> trail;
}
