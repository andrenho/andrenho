digraph g {

  size="11";

  start -> start_round;
  start_round -> next_nation;

  next_nation -> focus_next_unit [label="nations\nleft"];
  advance_round -> start_round;
  next_nation -> advance_round [label="no nations\nleft"];

  focus_next_unit -> listen [label="units with\nmoves left"];
  focus_next_unit -> next_nation [label="no units with\nmoves left"];
  focus_next_unit -> game_over [label="no units alive"];

  listen -> focus_next_unit [label="wait"];
  listen -> move [label="move,\nmoves left"];
  listen -> change_terrain [label="change terrain"];
  listen -> rest [label="rest and\nunits left"];
  listen -> next_nation [label="rest and\nno units left"];
  
  rest -> focus_next_unit;
  change_terrain -> focus_next_unit;
  move -> listen [label="moves left"];
  move -> focus_next_unit [label="no moves left"];
  listen -> join_city [label="join city"];
  listen -> build_city [label="build city"];
  build_city -> join_city;
  listen -> fight [label="attack"];
  fight -> focus_next_unit [label="win or die"];

  join_city -> focus_next_unit;
  build_city -> focus_next_unit;

  game_over -> end;

  start [shape=Mdiamond];
  end [shape=Mdiamond];
  listen [shape=square];
}
