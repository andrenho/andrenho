double_buffer yes

alignment top_right
background yes
border_width 1
border_inner_margin 10
border_outer_margin 20
cpu_avg_samples 4
default_bar_size 0 6
default_color white
default_shade_color 202020
draw_borders yes
draw_graph_borders yes
draw_outline yes
draw_shades yes
use_xft no
font -misc-fixed-medium-r-normal--18-*-100-100-c-*-iso8859-1
format_human_readable yes
xftfont DejaVu Sans Mono:size=12
gap_x 20
gap_y 20
maximum_width 500
minimum_size 5 5
net_avg_samples 2
no_buffers yes
out_to_console no
out_to_stderr no
extra_newline no
own_window no
own_window_class Conky
own_window_argb_visual yes
own_window_transparent no
own_window_type override
stippled_borders 0
update_interval 1.0
uppercase no
use_spacer none
show_graph_scale no
show_graph_range no

TEXT
$nodename - $sysname $kernel on $machine
$hr
${color grey}Uptime:$color $uptime
${color grey}Frequency (in MHz):$color $freq
${color grey}RAM Usage:$color $mem/$memmax - $memperc% 
${memgraph}
${color grey}CPU Usage:$color $cpu%    ${color grey}Temperature:$color $acpitempşC
${cpugraph}
${color grey}Processes:$color $processes  ${color grey}Running:$color $running_processes
$hr
${color grey}File systems:
 /     $color${fs_free /}
 /home $color${fs_free /home} 
${fs_bar_free 24 /home}
$hr
${color grey}Networking:
 Download ${downspeedgraph wlp3s0}
 Upload   ${upspeedgraph wlp3s0}
 ${color gray}Network:$color ${wireless_essid wlp3s0} (${wireless_link_qual_perc wlp3s0}%)
 ${color grey}Unread e-mails:$color ${execpi 60 ~/.scripts/gmail}
$hr
${color grey}Name              PID   CPU%   MEM%
${color lightgrey} ${top name 1} ${top pid 1} ${top cpu 1} ${top mem 1}
${color lightgrey} ${top name 2} ${top pid 2} ${top cpu 2} ${top mem 2}
${color lightgrey} ${top name 3} ${top pid 3} ${top cpu 3} ${top mem 3}
${color lightgrey} ${top name 4} ${top pid 4} ${top cpu 4} ${top mem 4}
