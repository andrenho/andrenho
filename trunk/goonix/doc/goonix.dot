digraph G {

rankdir=LR;

pm [label="Process\nManager", shape=rectangle];
syscall [label="Syscall\nServer", shape=rectangle];
dev [label="Device\nManager", shape=rectangle];
fm [label="Filesystem\nManager", shape=rectangle];
dll [label="Syscall\nDLL", shape=rectangle];
terminal [label="Terminal\nExecutable", shape=rectangle];

subgraph cluster_0 { label = "Goonix"; pm syscall dev fm VirtualFS Threads }
subgraph cluster_1 { label = "Host"; Processes RealFS }

pm -> Processes;
pm -> Threads;
Processes -> dll;
Threads -> dll;
dll -> syscall;

fm -> VirtualFS;
fm -> RealFS;

terminal -> dev;

}
