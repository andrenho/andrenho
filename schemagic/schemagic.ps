%!PS

%
% initialization
%
/initfont {
   /New-Century-Schoolbook findfont
   9 scalefont
   setfont
} def

/init-schemagic {
   initfont
   0 0 moveto
   2 setlinecap
   2 setlinejoin
   70 780 translate
} def

/t { translate } def

% 
% helping functions
%
/center {
   moveto dup stringwidth pop -2 div 0 rmoveto show
} def

%
% drawing
%
/grid { % w h grid
   /h exch def
   10 mul /w exch def
   gsave
      newpath
      -40 40 moveto
      [0.3 9.7] 0 setdash
      0.5 setlinewidth
      h {
         w 0 rlineto
         0 w sub -10 rmoveto
      } repeat
      stroke
   grestore
} def

%
% components
%
/wire { % size wire
   gsave
      newpath
      0 0 moveto
      -10 mul 0
      exch
      2 copy % return values
      rlineto
      stroke
   grestore
} def


/nothing { % size nothing
   gsave
      newpath 0 0 moveto
      -10 mul 0
      exch
      2 copy % return values
      rmoveto
      stroke
   grestore
} def


/battery { % cells voltage battery
   gsave
      newpath
      0  0 moveto
      gsave % text
        17 -22 moveto
        show
      grestore
      gsave % plus sign
        4 -9 moveto
        (+) show
      grestore
      0 -14 rlineto % drawing
      0  4 rmoveto
      dup {
         0 -4 rmoveto
       -10  0 rlineto % top (big) bar
        20  0 rlineto
       -10 -4 rmoveto
        -4  0 rlineto % bottom (small) bar
         8  0 rlineto
        -4  0 rmoveto
      } repeat
      0 -13 rlineto
      2 sub 0 exch 8 mul % (2 - cells) * 6
      rlineto
      stroke
   grestore
   0 -40 rmoveto
   0 -40 % return values
} def

/resistor { % (resistence) resistor
   /resistence exch def
   gsave % text
     10 -22 moveto
     resistence show
   grestore
   gsave
      newpath     % image
      0 0 moveto
      0 -8 rlineto
      4 -2 rlineto
      2 {
         -8 -4 rlineto
          8 -4 rlineto
      } repeat
      -8 -4 rlineto
      4 -2 rlineto
      0 -7 rlineto
      stroke
   grestore
   0 -40 rmoveto
   0 -40 % return values
} def

/conn { % conn
   gsave
      newpath 0 0 moveto 
      0 0 2 0 360 arc closepath fill 
      stroke
   grestore
   0 0
} def

/icpin {
   /label exch def
   gsave
      newpath 0 0 moveto
      20 0 rlineto
      0 9 rlineto
      stroke
   grestore
   20 0
} def

/icnopin {
   gsave
      newpath 0 0 moveto
      19 0 rlineto
      stroke
   grestore
   20 0
} def

/icname {
   /w exch def
   /h exch def
   /label exch def
   gsave
      newpath 0 0 moveto
      /New-Century-Schoolbook findfont
      13 scalefont setfont
      w 20 mul 2 div % position x
      0 rmoveto
      label 0 0 center
   grestore
   0 0
} def

% 
% main document
%
init-schemagic
% 30 30 grid

(220) resistor t
4 wire t
(4048) 5 2 icname
(A1) icpin t
gsave
   180 rotate
   1 nothing t 3 wire t
   90 rotate
   2 wire t conn t 6 wire t
   90 rotate
   8 wire t
grestore
(A2) icpin t
(A3) icpin t
(A4) icpin t
icnopin t -90 rotate 
(B1) icpin t
(B2) icpin t
icnopin t -90 rotate 
(C1) icpin t
(C2) icpin t
(C3) icpin t
(C4) icpin t
(C5) icpin t
icnopin t -90 rotate 
(D1) icpin t
icnopin t
icnopin t -90 rotate
icnopin t
%() resistor t

showpage
