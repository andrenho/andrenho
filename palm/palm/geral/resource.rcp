FORM ID BuscaClienteFrm AT (0 0 159 159) USABLE NOFRAME
BEGIN
	TITLE "Clientes"
END

ALERT ID ToBeDone WARNING
BEGIN
	TITLE "A Fazer"
	MESSAGE "Esta funçăo năo está implementada."
	BUTTONS "Ok"
END

ALERT ID Debug ERROR
BEGIN
	TITLE "Debug"
	MESSAGE "^1, ^2, ^3"
	BUTTONS "Ok"
END

ALERT ID ClienteNaoExiste ERROR
BEGIN
	TITLE "Cliente Inexistente"
	MESSAGE "Este cliente năo está cadastrado."
	BUTTONS "Ok"
END
