ALERT ID ToBeDone WARNING
BEGIN
	TITLE "WG-Soft"
	MESSAGE "Esta funÁ„o n„o estŠ implementada."
	BUTTONS "Ok"
END

ALERT ID Debug ERROR
BEGIN
	TITLE "Debug"
	MESSAGE "^1, ^2, ^3"
	BUTTONS "Ok"
END

ALERT ID ClienteNaoExiste ERROR
BEGIN
	TITLE "WG-Soft"
	MESSAGE "Este cliente n„o estŠ cadastrado."
	BUTTONS "Ok"
END

ALERT ID ProdutoNaoExiste ERROR
BEGIN
	TITLE "WG-Soft"
	MESSAGE "Este produto n„o estŠ cadastrado."
	BUTTONS "Ok"
END

ALERT ID MensagemErro ERROR
BEGIN
	TITLE "WG-Soft"
