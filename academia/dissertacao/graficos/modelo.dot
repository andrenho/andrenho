digraph modelo {

  //layout = fdp;
  rankdir = LR;
  sep = 0.3;

  node [style=filled,fillcolor=white,fontname="FreeSerif"];

  // externos
  node [shape=box]; 
    GerenciadorDeTrilhas [label="Gerenciador\n de Trilhas"]; 
    Aplicação;

  // ontologias
  node [shape=hexagon,fixedsize=true,width=1.1,height=0.8]; 
    OntologiaDeTrilha [label="Ontologia\nde Trilha"];
    OntologiaDePerfil [label="Ontologia\nde Perfil",style="bold,filled"];
    BaseDeRegras [label="Base de\nRegras"];

  // agentes
  node [shape=oval,fixedsize=true,width=1.3];
    Regulador;
    Raciocinador;
    Conversor;

//node [shape=diamond];
//  Entidade;

  subgraph cluster_eProfile {
    label = "eProfile";
    style = filled;
    fillcolor = lightgrey;
    Conversor -> OntologiaDeTrilha;
    Regulador -> BaseDeRegras;
    BaseDeRegras -> Raciocinador;
    OntologiaDeTrilha -> Raciocinador;
    Raciocinador -> OntologiaDePerfil;
  }

  subgraph cluster_ext {
    style = invisible;
//  Entidade -> Aplicação;
    Aplicação -> Regulador;
    OntologiaDePerfil -> Aplicação;
  }
  
  Aplicação -> GerenciadorDeTrilhas -> Conversor;

  fontsize = 12;
}
