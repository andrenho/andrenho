digraph modelo {

  node [style=filled,fillcolor=white];
  node [shape=box]; "Gerenciador\nde trilhas"; "Cliente";
  node [shape=hexagon,fixedsize=true,width=1.1,height=0.8]; 
    "Ontologia\nde Trilha"; "Ontologia\nde Perfil";
    "Base de\nRegras";
  node [shape=oval,fixedsize=true,width=1.3];

  
  subgraph cluster_eProfile {
    label = "eProfile";
    style = filled;
    fillcolor = lightgrey;
    Mediador -> "Ontologia\nde Trilha";
    "Administrador\nde regras" -> "Base de\nRegras";
    "Base de\nRegras" -> Raciocinador;
    "Ontologia\nde Trilha" -> Raciocinador;
    Raciocinador -> "Ontologia\nde Perfil";
  }

  "Cliente" -> "Gerenciador\nde trilhas" -> Mediador;
  "Cliente" -> "Administrador\nde regras";
  "Ontologia\nde Perfil" -> "Cliente" [style=dotted];

  overlap = false;
  rankdir = LR;
  // label = "Modelo eProfile";
  fontsize = 12;
}
