digraph G {

  rankdir = LR;
	node [shape=record];
  LOCAL;
  UniManager;
  trail [label="Trail Manager"];
  cadastro [label="Registration|{Time|Event date}|{Identity|Student}"];
  matricula [label="Enrollment|{Time|Event date}|{Identity|Student}"];
  trocalocal [label="ChangeLocation|{Activity|Entry or exit}|{Time|Event time}|{Location|Location}|{Identity|Student}"];
  prova [label="TestPaper|{Activity|Paper delivered}|{Time|Event time}|{Location|Location}|{Identity|Student}|{Participants|Workgroup}"];
  preferencia [label="Preference|{Activity|Preference}|{Time|Event time}|{Identity|Student}"];
  abandono [label="Abandonment|{Time|Event date}|{Identity|Student}"];

  UniManager -> cadastro -> trail;
  UniManager -> matricula -> trail;
  UniManager -> trocalocal -> trail;
  UniManager -> prova -> trail;
  UniManager -> abandono -> trail;
  LOCAL -> trocalocal;
  LOCAL -> preferencia -> trail;

}
