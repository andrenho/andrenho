digraph G {

  rankdir = LR;
	node [shape=record];
  UniManager;
  trail [label="Trail Manager"];
  cadastro [label="Registration|{Time|Event date}|{Identity|Professor}"];
  trocalocal [label="ChangeLocation|{Activity|Entry or exit}|{Time|Event time}|{Location|Location}|{Identity|Professor}"];
  avaliacao [label="Evaluation|{Activity|Evaluation}|{Time|Event time}|{Location|Location}|{Identity|Professor}"];

  UniManager -> trocalocal -> trail;
  UniManager -> cadastro -> trail;
  UniManager -> avaliacao -> trail;
}
