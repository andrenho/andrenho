digraph G {

  rankdir = LR;
  node [shape=record];
  UniManager;
  trail [label="Trail Manager"];
  cadastro [label="Registration|{Time|Event date}|{Identity|Discipline}"];
  semestre [label="Semester|{Activity|Beginning or end}|{Identity|Discipline}|{Time|Date}|{Participantes|Faculty and students}"];
  trabalho [label="Workgroup|{Activity|Subjects}|{Identity|Discipline}|{Time|Date}|{Participants|Students}"];

  UniManager -> cadastro -> trail;
  UniManager -> semestre -> trail;
  UniManager -> trabalho -> trail;
}
