digraph G {

  rankdir = LR;
	node [shape=record];
  LOCAL;
  UniManager;
  trail [label="Gerenciador\nde trilhas"];
  cadastro [label="Cadastro|{Time|Data do evento}|{Indentity|Estudante}"];
  matricula [label="Matrícula|{Time|Data do evento}|{Indentity|Estudante}"];
  trocalocal [label="TrocaLocal|{Activity|Entrada ou saida}|{Time|Hora do evento}|{Location|Localização}|{Indentity|Estudante}"];
  prova [label="ProvaTrabalho|{Activity|Trabalho entregue}|{Time|Hora do evento}|{Location|Localização}|{Indentity|Estudante}|{Participantes|Grupo de trabalho}"];
  preferencia [label="Preferência|{Activity|Preferência}|{Time|Hora do Evento}|{Indentity|Estudante}"];
  abandono [label="Abandono|{Time|Data do evento}|{Indentity|Estudante}"];

  UniManager -> cadastro -> trail;
  UniManager -> matricula -> trail;
  UniManager -> trocalocal -> trail;
  UniManager -> prova -> trail;
