digraph Perfil {

    perfil -> educacao
    perfil -> profissional

    educacao -> ISAM
    educacao -> LOCAL
    profissional -> MUCS

    educacao -> P1
    profissional -> P2

    ISAM -> NP1
    LOCAL -> NP2
    MUCS -> NP3
    
    P1 [label="P", shape=box]
    NP1 [label="NP", shape=box]
    P2 [label="P", shape=box]
    NP2 [label="NP", shape=box]
    NP3 [label="NP", shape=box]

}
